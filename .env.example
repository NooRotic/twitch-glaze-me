# Client ID from https://dev.twitch.tv/console/apps
VITE_TWITCH_CLIENT_ID=

# OAuth redirect URI — MUST byte-match what's registered in your Twitch app.
# Leave blank to auto-compute from `window.location.origin + BASE_URL`
# (works on production/GitHub Pages). For local dev set it explicitly because
# Vite's base path adds a trailing slash and Twitch matches exact strings.
# Dev example (matches vite.config.ts port 5000):
#   VITE_TWITCH_REDIRECT_URI=http://localhost:5000/twitch-glaze-me
VITE_TWITCH_REDIRECT_URI=
